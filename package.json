{
  "name": "cybersim-ui",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@risingstack/react-easy-state": "^6.3.0",
    "@testing-library/jest-dom": "^5.11.2",
    "@testing-library/react": "^10.4.7",
    "@testing-library/user-event": "^12.1.0",
    "axios": "0.21.1",
    "bootstrap": "^4.5.0",
    "classnames": "^2.2.6",
    "lodash": "^4.17.19",
    "query-string": "^6.13.1",
    "react": "^16.13.1",
    "react-bootstrap": "^1.3.0",
    "react-dom": "^16.13.1",
    "react-icons": "^3.10.0",
    "react-router-dom": "^6.2.2",
    "react-scripts": "^5.0.1",
    "socket.io-client": "^4.5.0"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "husky": "^4.2.5",
    "prettier": "^2.0.5",
    "sass": "^1.97.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  },
  "scripts": {
    "copy_dotenv": "cp .env.example .env",
    "project:start": "npm i && npm run copy_dotenv && npm run start",
    "test:init": "npx playwright install",
    "test:e2e": "npm run test:init && npx playwright test --headed",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint --max-warnings 0 --ext js,jsx src"
  },
  "eslintConfig": {
    "extends": "react-app",
    "rules": {
      "import/no-anonymous-default-export": "off"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
